@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

if(NOT TARGET Qt6::Core AND NOT TARGET Qt5::Core)
    find_dependency(QT NAMES Qt6 Qt5 REQUIRED COMPONENTS Core Widgets)
    find_dependency(Qt${QT_VERSION_MAJOR} REQUIRED COMPONENTS Core Widgets)
endif()

include("${CMAKE_CURRENT_LIST_DIR}/ArchitectGenLibrariesTargets.cmake")
